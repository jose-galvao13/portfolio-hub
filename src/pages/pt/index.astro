---
import Layout from '../../layouts/pt/Layout.astro';
import ProjectCard from '../../components/pt/ProjectCard.astro';
import profileImage from '../../assets/images/profile.png';
import liquilentesLogo from '../../assets/images/liquilentes.png';
import { getProjects } from '../../data/pt/projects';

const currentYear = new Date().getFullYear();
const allProjects  = getProjects(import.meta.env.BASE_URL);
const featuredProjects = allProjects.filter(p => p.featured);
const otherProjects    = allProjects.filter(p => !p.featured);
---

<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-ZVWG09RGY6"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-ZVWG09RGY6');
</script>

<Layout title="José Galvão | Portfólio" currentLang="pt">
  <!-- Barra de Progresso de Scroll -->
  <div class="scroll-progress" id="scrollProgress"></div>

  <br>

  <!-- SECÇÃO HERO -->
  <section id="about" class="hero">
    <div class="container">
      <div class="profile-pic-wrapper">
        <img src={profileImage.src} alt="José Galvão" class="profile-pic hero-reveal">
      </div>
      <h1 class="reveal">José Galvão</h1>
      <h3 class="reveal" data-i18n="hero.role">Analista de Dados de Empresas</h3>
      <div class="hero-description reveal" data-i18n="hero.description">
        Estudante de Gestão de Empresas no ISCAC &amp; programador autodidata.<br>
        Transformo processos manuais e repetitivos em sistemas automatizados —
        desde pipelines ETL até modelos ML que impulsionam decisões de negócio reais.
      </div>

      <div class="skill-pills">
        <span class="skill-pill" data-tooltip="Proficiência avançada" data-i18n="skills.tooltip.python" data-i18n-attr="data-tooltip">Python</span>
        <span class="skill-pill" data-tooltip="Otimização de queries" data-i18n="skills.tooltip.sql" data-i18n-attr="data-tooltip">SQL</span>
        <span class="skill-pill" data-tooltip="DAX e visualização" data-i18n="skills.tooltip.powerbi" data-i18n-attr="data-tooltip">Power BI</span>
        <span class="skill-pill" data-tooltip="Scikit-learn e TensorFlow" data-i18n="skills.tooltip.ml" data-i18n-attr="data-tooltip">Machine Learning</span>
        <span class="skill-pill" data-tooltip="DCF e previsão" data-i18n="skills.tooltip.finance" data-i18n-attr="data-tooltip">Modelação Financeira</span>
      </div>

      <div class="hero-buttons">
        <a href="https://linkedin.com/in/jose-galvão" target="_blank" rel="noopener noreferrer" class="custom-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
          </svg>
          <span data-i18n="hero.btn.linkedin">LinkedIn</span>
        </a>
        <a href="https://github.com/jose-galvao13" target="_blank" rel="noopener noreferrer" class="custom-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <span data-i18n="hero.btn.github">GitHub</span>
        </a>
        <a href={`${import.meta.env.BASE_URL}/Jose_Galvao_CV_PT.pdf`} download class="custom-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
            <polyline points="13 2 13 9 20 9"></polyline>
          </svg>
          <span data-i18n="hero.btn.resume">Currículo</span>
        </a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- SECÇÃO DE ESTATÍSTICAS COM CONTADORES ANIMADOS -->
  <section class="stats-section">
    <div class="container">
      <h3><span data-i18n="stats.heading">Em</span> <span class="gradient-text" data-i18n="stats.headingAccent">Números</span></h3>
      <div class="stats-grid">
        <div class="stat-card reveal-stagger">
          <div class="stat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
            </svg>
          </div>
          <div class="stat-value" data-target={allProjects.length}>0</div>
          <div class="stat-desc" data-i18n="stats.projects.desc">Projetos de Ponta a Ponta</div>
          <div class="stat-context" data-i18n="stats.projects.ctx">Cada um com repositório GitHub público e estudo de caso documentado</div>
        </div>
        <div class="stat-card reveal-stagger">
          <div class="stat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
              <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
              <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
            </svg>
          </div>
          <div class="stat-value" data-target="5" data-suffix="00k+">0</div>
          <div class="stat-desc" data-i18n="stats.data.desc">Dados Processados</div>
          <div class="stat-context" data-i18n="stats.data.ctx">Armazém: 1,2M transações · E-Commerce: 100k · Imobiliário: 95k</div>
        </div>
        <div class="stat-card reveal-stagger">
          <div class="stat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="m9 12 2 2 4-4"></path>
            </svg>
          </div>
          <div class="stat-value" data-target="88" data-suffix="%">0</div>
          <div class="stat-desc" data-i18n="stats.accuracy.desc">Precisão Média dos Modelos</div>
          <div class="stat-context" data-i18n="stats.accuracy.ctx">Em 4 projetos ML (AUC/MAPE)</div>
        </div>
        <div class="stat-card reveal-stagger">
          <div class="stat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div class="stat-value" data-target="2" data-suffix="d→5s">0</div>
          <div class="stat-desc" data-i18n="stats.automation.desc">Automação Mais Rápida</div>
          <div class="stat-context" data-i18n="stats.automation.ctx">Relatório financeiro: fecho mensal de 2 dias para menos de 5 segundos</div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- SECÇÃO DE PROJETOS EM DESTAQUE -->
  <section id="portfolio" class="projects-section">
    <div class="container">
      <h2 class="gradient-text reveal" data-i18n="projects.featured">⭐ Projetos em Destaque</h2>

      <div class="filter-container">
        <span class="filter-label" data-i18n="projects.filterLabel">🔍 FILTRAR POR COMPETÊNCIAS</span>
        <div class="custom-select-wrapper">
          <select class="filter-select" id="skillFilter" aria-label="Filtrar projetos por competência">
            <option value="all" data-i18n="projects.filterAll">Todos os Projetos</option>
            <option value="Python">Python</option>
            <option value="SQL">SQL</option>
            <option value="Power BI">Power BI</option>
            <option value="Machine Learning">Machine Learning</option>
            <option value="Streamlit">Streamlit</option>
          </select>
          <span class="custom-arrow" aria-hidden="true"></span>
        </div>
      </div>

      <div class="projects-grid" id="featuredGrid">
        {featuredProjects.map((project, index) => (
          <ProjectCard
            title={project.title}
            type={project.type}
            desc={project.desc}
            stack={project.stack}
            linkRepo={project.linkRepo}
            linkDemo={project.linkDemo}
            caseStudy={project.caseStudy}
            images={project.images}
            imageAlts={project.imageAlts}
            id={`featured-${index}`}
            complexity={project.complexity}
            businessImpact={project.businessImpact}
            dataSection="featured"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- OUTROS PROJETOS (EXPANSÍVEL) -->
  <section class="other-projects-section">
    <div class="container">
      <button class="expand-projects-btn" id="expandBtn" aria-expanded="false" aria-controls="otherProjectsContainer">
        <span class="btn-text" data-i18n="projects.showMore">Mostrar Mais Projetos</span>
        <svg class="chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>

      <div class="collapsible-projects" id="otherProjectsContainer" aria-hidden="true">
        <div class="projects-grid" id="otherGrid">
          {otherProjects.map((project, index) => (
            <ProjectCard
              title={project.title}
              type={project.type}
              desc={project.desc}
              stack={project.stack}
              linkRepo={project.linkRepo}
              linkDemo={project.linkDemo}
              caseStudy={project.caseStudy}
              images={project.images}
              imageAlts={project.imageAlts}
              id={`other-${index}`}
              complexity={project.complexity}
              businessImpact={project.businessImpact}
              dataSection="other"
            />
          ))}
        </div>

        <button
          class="expand-projects-btn"
          id="collapseBtn"
          style="margin-top: 40px;"
          aria-controls="otherProjectsContainer"
        >
          <span class="btn-text" data-i18n="projects.showLess">Mostrar Menos Projetos</span>
          <svg class="chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="transform: rotate(180deg);">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- SECÇÃO DE LINHA DO TEMPO -->
  <section id="timeline" class="timeline-section">
    <div class="container">
      <h2 class="gradient-text">Experiência &amp; Formação</h2>
      <div class="timeline-grid">
        <div class="timeline-column">
          <h3>🎓 Formação</h3>
          <div class="timeline-item">
            <div class="timeline-date">2024 - Presente</div>
            <div class="timeline-title">Licenciatura em Gestão de Empresas</div>
            <div class="timeline-company">Escola Superior de Gestão de Coimbra (ISCAC)</div>
            <div class="timeline-desc">Foco: Controlo Financeiro, Análise de Dados.</div>
          </div>
          <div class="timeline-item">
            <div class="timeline-date">2021 - 2024</div>
            <div class="timeline-title">Informática de Gestão</div>
            <div class="timeline-company">Escola Secundária Avelar Brotero</div>
            <div class="timeline-desc">
              Curso Profissional abrangendo Lógica de Programação, Bases de Dados e Administração de Empresas.
            </div>
          </div>
        </div>

        <div class="timeline-column">
          <h3>💼 Experiência</h3>
          <div class="timeline-item">
            <div class="timeline-date">Set 2025 - Presente</div>
            <div class="timeline-title">Analista de Dados de Empresas &amp; Consultor de Automação</div>
            <div class="timeline-company">Freelance / Projetos Independentes</div>
            <ul class="timeline-list">
              <li>Especializado em arquitetar <b>automação de fluxos financeiros</b> e estruturas de dados robustas para eliminar estrangulamentos operacionais.</li>
              <li>Desenvolvendo <b>pipelines ETL</b> de ponta a ponta para centralizar dados fragmentados de sistemas ERP e ficheiros legados.</li>
              <li>Implementando <b>modelos de IA &amp; Machine Learning</b> para análise preditiva, focando na mitigação de risco e previsão de procura de alta precisão.</li>
              <li><b>Consultoria estratégica em Power BI</b>, entregando dashboards ao nível executivo focados em ROI, rentabilidade e tomada de decisão baseada em dados.</li>
            </ul>
          </div>
          <div class="timeline-item">
            <div class="timeline-date">Mar 2024 - Ago 2024</div>
            <div class="timeline-title">Assistente de Operações Júnior (Estágio)</div>
            <div class="timeline-company">Liquilentes | Coimbra</div>
            <ul class="timeline-list">
              <li><b>Melhorei a precisão do inventário</b> com apoio a controlos administrativos diários e acompanhamento logístico.</li>
              <li>Aprimorei os <b>processos de reconciliação com fornecedores</b> através de verificação e auditoria rigorosa de dados.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- SECÇÃO DE IDIOMAS -->
  <section id="languages" class="languages-section">
    <div class="container">
      <h2 class="gradient-text reveal">Idiomas</h2>
      <div class="lang-container">
        <div class="lang-card reveal-stagger">
          <img src="https://flagcdn.com/w160/pt.png" class="lang-flag-img" alt="Bandeira de Portugal">
          <div class="lang-name">Português</div>
          <div class="lang-level">Língua Materna</div>
          <div class="lang-bar-bg"><div class="lang-bar-fill" style="width: 100%;"></div></div>
        </div>
        <div class="lang-card reveal-stagger">
          <img src="https://flagcdn.com/w160/gb.png" class="lang-flag-img" alt="Bandeira do Reino Unido">
          <div class="lang-name">Inglês</div>
          <div class="lang-level">Avançado</div>
          <div class="lang-bar-bg"><div class="lang-bar-fill" style="width: 90%;"></div></div>
        </div>
        <div class="lang-card reveal-stagger">
          <img src="https://flagcdn.com/w160/es.png" class="lang-flag-img" alt="Bandeira de Espanha">
          <div class="lang-name">Espanhol</div>
          <div class="lang-level">Intermédio</div>
          <div class="lang-bar-bg"><div class="lang-bar-fill" style="width: 50%;"></div></div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- SECÇÃO DE EXPERTISE E PROFICIÊNCIA -->
  <section id="skills" class="skills-section">
    <div class="container">
      <h2 class="gradient-text" style="text-align: center; margin-bottom: 50px;">Expertise Técnica &amp; Proficiência</h2>

      <div class="combined-skills-grid">
        <div class="skill-group-card">
          <h3 class="skill-group-title"><span class="icon">🐍</span> Programação</h3>
          <div class="skill-items-container">
            <div class="compact-skill-item" data-tooltip="Pandas, NumPy, Scikit-learn">
              <div class="skill-top">
                <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/python/python-original.svg" alt="Logo Python">
                <span class="skill-name">Python</span>
              </div>
              <div class="skill-bar-bg"><div class="skill-bar-fill" style="width: 90%;"></div></div>
            </div>
            <div class="compact-skill-item" data-tooltip="Apps desktop e automação">
              <div class="skill-top">
                <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/csharp/csharp-original.svg" alt="Logo C#">
                <span class="skill-name">C# / .NET</span>
              </div>
              <div class="skill-bar-bg"><div class="skill-bar-fill" style="width: 75%;"></div></div>
            </div>
            <div class="compact-skill-item" data-tooltip="Automação web e testes">
              <div class="skill-top">
                <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/javascript/javascript-original.svg" alt="Logo JavaScript">
                <span class="skill-name">JavaScript</span>
              </div>
              <div class="skill-bar-bg"><div class="skill-bar-fill" style="width: 65%;"></div></div>
            </div>
          </div>
        </div>

        <div class="skill-group-card">
          <h3 class="skill-group-title"><span class="icon">📊</span> Dados &amp; BI</h3>
          <div class="skill-items-container">
            <div class="compact-skill-item" data-tooltip="DAX avançado e modelação de dados">
              <div class="skill-top">
                <img src="https://github.com/microsoft/PowerBI-Icons/raw/main/PNG/Power-BI.png" alt="Logo Power BI">
                <span class="skill-name">Power BI (DAX)</span>
              </div>
              <div class="skill-bar-bg"><div class="skill-bar-fill" style="width: 80%;"></div></div>
            </div>
            <div class="compact-skill-item" data-tooltip="Joins complexos e otimização">
              <div class="skill-top">
                <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/mysql/mysql-original.svg" alt="Logo SQL">
                <span class="skill-name">SQL (ETL)</span>
              </div>
              <div class="skill-bar-bg"><div class="skill-bar-fill" style="width: 65%;"></div></div>
            </div>
            <div class="compact-skill-item" data-tooltip="Macros VBA e fórmulas">
              <div class="skill-top">
                <img src="https://uxwing.com/wp-content/themes/uxwing/download/brands-and-social-media/microsoft-excel-icon.png" alt="Logo Microsoft Excel">
                <span class="skill-name">Excel (VBA)</span>
              </div>
              <div class="skill-bar-bg"><div class="skill-bar-fill" style="width: 90%;"></div></div>
            </div>
            <div class="compact-skill-item" data-tooltip="Star schema e armazém de dados">
              <div class="skill-top">
                <span class="icon" style="font-size: 14px;">🏗️</span>
                <span class="skill-name">Arquitetura de Dados</span>
              </div>
              <div class="skill-bar-bg"><div class="skill-bar-fill" style="width: 70%;"></div></div>
            </div>
          </div>
        </div>

        <div class="skill-group-card">
          <h3 class="skill-group-title"><span class="icon">🤖</span> IA &amp; Ciência de Dados</h3>
          <div class="skill-items-container">
            <div class="compact-skill-item" data-tooltip="Scikit-learn, Random Forest">
              <div class="skill-top">
                <img src="https://upload.wikimedia.org/wikipedia/commons/0/05/Scikit_learn_logo_small.svg" alt="Logo Scikit-learn" style="background:white; border-radius:4px; padding:2px;">
                <span class="skill-name">Machine Learning</span>
              </div>
              <div class="skill-bar-bg"><div class="skill-bar-fill" style="width: 60%;"></div></div>
            </div>
            <div class="compact-skill-item" data-tooltip="Bases de dados vetoriais e agentes">
              <div class="skill-top">
                <img src="https://avatars.githubusercontent.com/u/126733545?s=200&v=4" alt="Logo LangChain">
                <span class="skill-name">LangChain / RAG</span>
              </div>
              <div class="skill-bar-bg"><div class="skill-bar-fill" style="width: 65%;"></div></div>
            </div>
            <div class="compact-skill-item" data-tooltip="Dashboards interativos">
              <div class="skill-top">
                <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/streamlit/streamlit-original.svg" alt="Logo Streamlit">
                <span class="skill-name">Apps Streamlit</span>
              </div>
              <div class="skill-bar-bg"><div class="skill-bar-fill" style="width: 85%;"></div></div>
            </div>
            <div class="compact-skill-item" data-tooltip="Manipulação e análise de dados">
              <div class="skill-top">
                <img src="https://upload.wikimedia.org/wikipedia/commons/e/ed/Pandas_logo.svg" alt="Logo Pandas" style="background:white; border-radius:2px; padding:1px;">
                <span class="skill-name">Pandas &amp; NumPy</span>
              </div>
              <div class="skill-bar-bg"><div class="skill-bar-fill" style="width: 90%;"></div></div>
            </div>
          </div>
        </div>

        <div class="skill-group-card">
          <h3 class="skill-group-title"><span class="icon">💰</span> Finanças &amp; Operações</h3>
          <div class="skill-items-container">
            <div class="compact-skill-item" data-tooltip="Previsão e cenários">
              <div class="skill-top">
                <span class="icon" style="font-size: 14px;">📈</span>
                <span class="skill-name">Modelação Financeira</span>
              </div>
              <div class="skill-bar-bg"><div class="skill-bar-fill" style="width: 85%;"></div></div>
            </div>
            <div class="compact-skill-item" data-tooltip="DCF e cálculo WACC">
              <div class="skill-top">
                <span class="icon" style="font-size: 14px;">⚖️</span>
                <span class="skill-name">Avaliação (DCF)</span>
              </div>
              <div class="skill-bar-bg"><div class="skill-bar-fill" style="width: 70%;"></div></div>
            </div>
            <div class="compact-skill-item" data-tooltip="Normas contabilísticas portuguesas">
              <div class="skill-top">
                <span class="icon" style="font-size: 14px;">📓</span>
                <span class="skill-name">Contabilidade SNC</span>
              </div>
              <div class="skill-bar-bg"><div class="skill-bar-fill" style="width: 80%;"></div></div>
            </div>
