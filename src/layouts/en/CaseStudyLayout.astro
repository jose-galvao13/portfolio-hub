<script>
  function initCodeCopy() {
    const codeBlocks = document.querySelectorAll('pre');

    codeBlocks.forEach((block) => {
      // Avoid duplicating if script runs twice
      if (block.querySelector('.copy-code-btn')) return;

      const copyIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
      const checkIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;

      const button = document.createElement('button');
      button.className = 'copy-code-btn';
      button.type = 'button';
      button.setAttribute('aria-label', 'Copy code to clipboard');
      button.innerHTML = `${copyIcon}<span>Copy</span>`;

      // Insert the button as the FIRST CHILD of <pre>
      // <pre> already has position:relative via is:global, so absolute positioning works
      block.insertBefore(button, block.firstChild);

      button.addEventListener('click', async (e) => {
        e.stopPropagation();

        // Extract text from <code> if present, otherwise collect all text nodes excluding the button
        const codeEl = block.querySelector('code');
        const codeText = codeEl
          ? codeEl.innerText
          : Array.from(block.childNodes)
              .filter((node) => node !== button)
              .map((node) => ('innerText' in node ? (node as HTMLElement).innerText : node.textContent ?? ''))
              .join('');

        try {
          await navigator.clipboard.writeText(codeText.trim());
          button.classList.add('copied');
          button.innerHTML = `${checkIcon}<span>Copied!</span>`;
          setTimeout(() => {
            button.classList.remove('copied');
            button.innerHTML = `${copyIcon}<span>Copy</span>`;
          }, 2000);
        } catch (err) {
          console.error('Copy failed:', err);
        }
      });
    });
  }

  function initReadingProgress() {
    const bar = document.querySelector('.reading-progress') as HTMLElement;
    if (!bar) return;
    const updateProgress = () => {
      const winScroll = document.documentElement.scrollTop || document.body.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = Math.round((winScroll / height) * 100);
      bar.style.width = scrolled + '%';
      bar.setAttribute('aria-valuenow', String(scrolled));
    };
    window.addEventListener('scroll', updateProgress, { passive: true });
  }

  function initSidebarSticky() {
    const sidebar = document.querySelector('.sidebar-inner') as HTMLElement;
    const container = document.querySelector('.main-layout') as HTMLElement;
    if (!sidebar || !container) return;

    const handleSidebar = () => {
      if (window.innerWidth <= 1024) { sidebar.classList.remove('is-released'); return; }
      const winScroll = window.scrollY || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrollPercent = (winScroll / height) * 100;
      sidebar.classList.toggle('is-released', scrollPercent >= 80);
    };

    window.addEventListener('scroll', () => window.requestAnimationFrame(handleSidebar), { passive: true });
    window.addEventListener('resize', handleSidebar);
    handleSidebar();
  }

  function initNavigationFixes() {
    const navLinks = document.querySelectorAll('.nav-links a[href^="#"], .nav-cta-glow[href^="#"]');
    const logoLink = document.querySelector('.nav-logo');
    const currentPath = window.location.pathname;
    const basePath = currentPath.includes('/portfolio-hub') ? '/portfolio-hub/' : '/';
    const isHomepage =
      currentPath === basePath ||
      currentPath === basePath + 'index.html' ||
      currentPath.endsWith('/portfolio-hub') ||
      currentPath === '/' ||
      currentPath === '/index.html';

    navLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const hash = link.getAttribute('href');
        if (isHomepage) {
          e.preventDefault();
          document.querySelector(hash || '')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } else {
          window.location.href = basePath + hash;
        }
      });
    });

    if (logoLink && !isHomepage) {
      logoLink.addEventListener('click', (e) => {
        e.preventDefault();
        window.location.href = basePath;
      });
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    initCodeCopy();
    initReadingProgress();
    initSidebarSticky();
    initNavigationFixes();
  });
</script>