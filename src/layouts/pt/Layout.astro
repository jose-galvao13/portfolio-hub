---
import '../../styles/global.css';
import { Image } from 'astro:assets';
import logoImg from '../../assets/images/logo.png';
import LanguageSwitcher from '../../components/LanguageSwitcher.astro';
import { getProjects } from '../../data/pt/projects';

interface Props {
  title: string;
  description?: string;
  currentLang?: 'en' | 'pt';
}

const { 
  title, 
  description = "Analista de Dados de Negócio especializado em automação Python, ML e engenharia de dados financeiros. Mais de 200h de trabalho manual eliminadas com soluções de IA.",
  currentLang = 'pt'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://josegalvao.com');
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/?$/, '/');
const currentLocale = Astro.currentLocale || 'pt';
const allProjectsData = getProjects(import.meta.env.BASE_URL);

// ── DADOS 100% DINÂMICOS de projects.ts ──────────────────────────────────────
const skillFilters = ['Python', 'SQL', 'Power BI', 'Machine Learning', 'Streamlit'] as const;
type Skill = typeof skillFilters[number];

// Agrupa todos os projetos reais por skill (sem hardcoding)
const megaMenuProjects: Record<Skill, { name: string; type: string; url: string }[]> = {
  'Python':           [],
  'SQL':              [],
  'Power BI':         [],
  'Machine Learning': [],
  'Streamlit':        [],
};

for (const project of allProjectsData) {
  for (const skill of skillFilters) {
    if (project.stack.some(s => s === skill || s.toLowerCase().includes(skill.toLowerCase()))) {
      megaMenuProjects[skill].push({
      name: project.title,
      type: project.type,
      url: project.caseStudy
        ? `${base}${currentLocale}/${project.caseStudy}`
        : project.linkRepo,
    });
    }
  }
}

// Contagens reais (igual ao tamanho do array dinâmico)
const skillCounts: Record<string, number> = {};
for (const skill of skillFilters) {
  skillCounts[skill] = megaMenuProjects[skill].length;
}
---

<!DOCTYPE html>
<html lang={currentLang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://www.googletagmanager.com">
  
  <title>{title}</title>
  <meta name="title" content={title}>
  <meta name="description" content={description}>
  <meta name="author" content="José Galvão">
  <meta name="keywords" content="analista de dados de negócio, automação python, engenheiro machine learning, modelação financeira, pipelines ETL, consultor power bi, engenharia de dados, soluções IA">
  <meta name="theme-color" content="#0EA5E9">
  
  <link rel="canonical" href={canonicalURL}>
  <link rel="icon" type="image/png" sizes="32x32" href={logoImg.src}>
  <link rel="apple-touch-icon" sizes="180x180" href={logoImg.src}>
  <link rel="mask-icon" href={logoImg.src} color="#0EA5E9">
  
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:title" content="José Galvão | Analista de Dados de Negócio & Especialista em Automação">
  <meta property="og:description" content="Eliminando mais de 200h de trabalho manual através de automação Python, modelos ML e engenharia de dados financeiros.">
  <meta property="og:image" content={new URL('/og-image.png', Astro.site || 'https://josegalvao.com')}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:site_name" content="José Galvão Portfólio">
  <meta property="og:locale" content="pt_PT">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content={canonicalURL}>
  <meta name="twitter:title" content="José Galvão | Analista de Dados de Negócio">
  <meta name="twitter:description" content="Especialista em automação Python e ML. 11 projetos, mais de 500k dados processados, 90% de precisão média.">
  <meta name="twitter:image" content={new URL('/og-image.png', Astro.site || 'https://josegalvao.com')}>
  
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "José Galvão",
    "jobTitle": "Analista de Dados de Negócio",
    "description": "Especialista em automação Python e engenheiro ML com experiência em engenharia de dados financeiros",
    "url": "https://josegalvao.com",
    "sameAs": ["https://linkedin.com/in/jose-galvão","https://github.com/jose-galvao13"],
    "address": { "@type": "PostalAddress", "addressLocality": "Coimbra", "addressCountry": "PT" },
    "alumniOf": { "@type": "EducationalOrganization", "name": "Coimbra Business School (ISCAC)" },
    "knowsAbout": ["Programação Python","Machine Learning","Engenharia de Dados","Modelação Financeira","Business Intelligence","Pipelines ETL","Power BI","SQL"]
  }
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
  
  <style>
    html { visibility: visible; opacity: 1; }
  </style>

  <script async src="https://www.googletagmanager.com/gtag/js?id=G-ZVWG09RGY6"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-ZVWG09RGY6', { page_path: window.location.pathname, anonymize_ip: true, cookie_flags: 'SameSite=None;Secure' });
  </script>

  <style>
    .nav-lang-wrapper {
      display: flex;
      align-items: center;
      margin-left: 1rem;
    }
    
    @media (max-width: 768px) {
      .nav-lang-wrapper {
        width: 100%;
        justify-content: center;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
      }
    }
  </style>
</head>
<body>

  <nav id="main-nav" role="navigation" aria-label="Navegação principal">
    <div class="nav-container">
      <div class="nav-content">
        
        <!-- LOGO -->
        <a href="#about" class="nav-logo" aria-label="José Galvão - Início">
          <div class="logo-hexagon-wrapper">
            <Image 
              src={logoImg} 
              alt="Logótipo JG"
              class="logo-image"
              width={80}
              height={80}
              quality={90}
              format="webp"
              loading="eager"
              decoding="async"
            />
          </div>
        </a>
        
        <!-- Menu Desktop -->
        <div class="nav-menu" id="nav-menu">
          <ul class="nav-links" role="list">

            <!-- PROJETOS com Mega Menu -->
            <li class="nav-item-mega" id="nav-projects-item">
              <a href="#portfolio" class="nav-link-mega" id="nav-projects-trigger" aria-haspopup="true" aria-expanded="false" data-i18n="nav.projects">Projetos
                <svg class="mega-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </a>

              <!-- PAINEL DO MEGA MENU -->
              <div class="mega-menu" id="mega-menu-panel" role="region" aria-label="Projetos por competência">
                <div class="mega-menu-inner">

                  <!-- ESQUERDA: Filtros de competência -->
                  <div class="mega-left">
                    <p class="mega-section-label" data-i18n="nav.filterSkill">Filtrar por Competência</p>
                    <ul class="mega-skill-list" role="list">
                      {skillFilters.map((skill, idx) => (
                        <li>
                          <button
                            class={`mega-skill-btn${idx === 0 ? ' active' : ''}`}
                            data-skill={skill}
                            type="button"
                            aria-pressed={idx === 0 ? 'true' : 'false'}
                          >
                            <span class="mega-skill-dot" aria-hidden="true"></span>
                            {skill}
                            <span class="mega-skill-count">{skillCounts[skill]}</span>
                          </button>
                        </li>
                      ))}
                    </ul>
                    <a href="#portfolio" class="mega-view-all" data-i18n="nav.viewAll">Ver todos os projetos
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                      </svg>
                    </a>
                  </div>

                  <!-- DIVISOR -->
                  <div class="mega-divider" aria-hidden="true"></div>

                  <!-- DIREITA: Lista de projetos por competência (com scroll) -->
                  <div class="mega-right">
                    <p class="mega-section-label mega-right-label" id="mega-right-label">Projetos Python</p>
                    <div class="mega-project-scroll" id="mega-project-scroll">
                      <ul class="mega-project-list" id="mega-project-list" role="list">
                        {skillFilters.map((skill) => (
                          megaMenuProjects[skill].map((p, idx) => (
                            <li
                              class={`mega-project-item${skill === skillFilters[0] ? ' animating visible' : ''}`}
                              data-skill={skill}
                              style={`--item-i: ${idx}`}
                            >
                              <a href={p.url} class="mega-project-link">
                                <span class="mega-proj-icon" aria-hidden="true">
                                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="16 18 22 12 16 6"></polyline>
                                    <polyline points="8 6 2 12 8 18"></polyline>
                                  </svg>
                                </span>
                                <span class="mega-proj-info">
                                  <span class="mega-proj-name">{p.name}</span>
                                  <span class="mega-proj-type">{p.type}</span>
                                </span>
                                <svg class="mega-proj-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                  <path d="M5 12h14M12 5l7 7-7 7"/>
                                </svg>
                              </a>
                            </li>
                          ))
                        ))}
                      </ul>
                    </div>
                    <!-- Indicador de fade quando há mais itens abaixo -->
                    <div class="mega-scroll-fade" id="mega-scroll-fade" aria-hidden="true"></div>
                  </div>

                </div>
              </div>
              <!-- Fim do Painel do Mega Menu -->
            </li>

            <li><a href="#timeline" data-i18n="nav.experience">Experiência</a></li>
            <li><a href="#skills" data-i18n="nav.skills">Competências</a></li>
            <li><a href="#recommendations" data-i18n="nav.recommendations">Recomendações</a></li>
            <li><a href="#efficiency" data-i18n="nav.roi">Impacto ROI</a></li>
            
            <!-- Seletor de Idioma - COM REDIRECIONAMENTO -->
            <div class="lang-switcher" id="langSwitcher" role="group" aria-label="Language selector">
  <button
    class={`lang-btn lang-btn--en${currentLang === 'en' ? ' active' : ''}`}
    data-lang="en"
    data-target-url={`${base}en`}
    aria-pressed={currentLang === 'en' ? 'true' : 'false'}
    title="Switch to English"
    type="button"
  >
    <img src="https://flagcdn.com/w20/gb.png" alt="" aria-hidden="true" class="lang-flag-img" width="20" height="14" />
    <span class="lang-label">EN</span>
  </button>

  <span class="lang-divider" aria-hidden="true">|</span>

  <button
    class={`lang-btn lang-btn--pt${currentLang === 'pt' ? ' active' : ''}`}
    data-lang="pt"
    data-target-url={`${base}pt`}
    aria-pressed={currentLang === 'pt' ? 'true' : 'false'}
    title="Switch to Portuguese"
    type="button"
  >
    <img src="https://flagcdn.com/w20/pt.png" alt="" aria-hidden="true" class="lang-flag-img" width="20" height="14" />
    <span class="lang-label">PT</span>
  </button>
</div>
          </ul>
        </div>

        <!-- CTA -->
        <div class="nav-actions">
          <a href="#contact" class="nav-cta-glow" data-i18n="nav.contact">Falar Comigo</a>
          <button 
            class="mobile-menu-btn" 
            id="mobile-menu-btn"
            aria-label="Abrir/fechar menu móvel"
            aria-expanded="false"
            aria-controls="nav-menu"
          >
            <span class="bar" aria-hidden="true"></span>
            <span class="bar" aria-hidden="true"></span>
            <span class="bar" aria-hidden="true"></span>
          </button>
        </div>
      </div>
    </div>
  </nav>

  <main id="main-content">
    <slot />
  </main>

  <style>
.nav-links {
  align-items: center; /* garante que todos os li ficam centrados */
}

    .lang-switcher {
      display: flex;
      align-items: center;
      gap: 2px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 8px;
      padding: 3px 6px;
      margin-left: 12px;
    }

    .lang-btn {
      display: flex;
      align-items: center;
      gap: 4px;
      background: none;
      border: none;
      border-radius: 5px;
      padding: 3px 7px;
      cursor: pointer;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--text-secondary, #9da5b0);
      transition: color 0.2s, background 0.2s;
      line-height: 1;
    }

    .lang-btn:hover {
      color: var(--text-primary, #f0f0f0);
      background: rgba(255,255,255,0.08);
    }

    .lang-btn.active {
      color: var(--accent-cyan, #0EA5E9);
      background: rgba(14, 165, 233, 0.12);
    }


    .lang-divider {
      color: rgba(255,255,255,0.15);
      font-size: 0.65rem;
      user-select: none;
      pointer-events: none;
      padding: 0 1px;
    }

    .lang-flag-img {
  width: 20px;
  height: 14px;
  border-radius: 2px;
  object-fit: cover;
  display: inline-block;
  vertical-align: middle;
}

/* Remove a regra antiga .lang-flag se existir */
@media (max-width: 380px) {
  .lang-flag-img { display: none; }
}
  </style>

  <script define:vars={{ currentLang }}>
    // ============================================
    // SELETOR DE IDIOMA - COM REDIRECIONAMENTO
    // ============================================
    function initLanguageSwitcher() {
      const langButtons = document.querySelectorAll('.lang-btn');

      langButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const targetUrl = btn.dataset.targetUrl;
          const targetLang = btn.dataset.lang;
          
          if (targetUrl && targetLang) {
            // Guardar preferência
            localStorage.setItem('preferredLanguage', targetLang);
            document.cookie = `preferredLanguage=${targetLang}; path=/; max-age=31536000`;
            
            // Redirecionar para a página correta
            window.location.href = targetUrl;
          }
        });
      });
    }

    // Inicializar ao carregar a página
    initLanguageSwitcher();

    // ============================================
    // EFEITO DE SCROLL NA NAVBAR
    // ============================================
    const nav = document.getElementById('main-nav');
    let ticking = false;
    
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          nav?.classList.toggle('scrolled', window.scrollY > 30);
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    // ============================================
    // TOGGLE DO MENU MÓVEL
    // ============================================
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('nav-menu');
    
    btn?.addEventListener('click', () => {
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isExpanded));
      btn.classList.toggle('active');
      menu?.classList.toggle('active');
      if (!isExpanded) menu?.querySelector('a')?.focus();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu?.classList.contains('active')) btn?.click();
    });

    // ============================================
    // MEGA MENU — lógica de hover / foco
    // ============================================
    const megaItem    = document.getElementById('nav-projects-item');
    const megaPanel   = document.getElementById('mega-menu-panel');
    const megaTrigger = document.getElementById('nav-projects-trigger');
    const skillBtns   = document.querySelectorAll('.mega-skill-btn');
    const projectItems= document.querySelectorAll('.mega-project-item');
    const rightLabel  = document.getElementById('mega-right-label');

    if (megaItem && megaPanel && megaTrigger) {

      // Abrir / fechar ao passar o rato (desktop)
      let closeTimer;

      const openMega = () => {
        clearTimeout(closeTimer);
        megaPanel.classList.add('open');
        megaTrigger.setAttribute('aria-expanded', 'true');
      };

      const closeMega = () => {
        closeTimer = setTimeout(() => {
          megaPanel.classList.remove('open');
          megaTrigger.setAttribute('aria-expanded', 'false');
        }, 150);
      };

      megaTrigger.addEventListener('mouseenter', openMega);
      megaItem.addEventListener('mouseleave', (e) => {
        if (!megaItem.contains(e.relatedTarget)) closeMega();
      });
      megaPanel.addEventListener('mouseenter', openMega);
      megaPanel.addEventListener('mouseleave', (e) => {
        if (!megaItem.contains(e.relatedTarget)) closeMega();
      });

      // Alternar ao clicar (toque / teclado)
      megaTrigger.addEventListener('click', (e) => {
        e.preventDefault();
        const isOpen = megaPanel.classList.contains('open');
        isOpen ? closeMega() : openMega();
      });

      // Fechar ao clicar fora
      document.addEventListener('click', (e) => {
        if (!megaItem.contains(e.target)) {
          megaPanel.classList.remove('open');
          megaTrigger.setAttribute('aria-expanded', 'false');
        }
      });

      // Fechar com ESC
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          megaPanel.classList.remove('open');
          megaTrigger.setAttribute('aria-expanded', 'false');
          megaTrigger.focus();
        }
      });

      // ---- Alternância de filtros de competência ----
      const scrollContainer = document.getElementById('mega-project-scroll');
      const scrollFade      = document.getElementById('mega-scroll-fade');

      function updateFade() {
        if (!scrollContainer || !scrollFade) return;
        const atBottom = scrollContainer.scrollTop + scrollContainer.clientHeight >= scrollContainer.scrollHeight - 8;
        scrollFade.classList.toggle('visible', !atBottom && scrollContainer.scrollHeight > scrollContainer.clientHeight);
      }

      scrollContainer?.addEventListener('scroll', updateFade, { passive: true });

      function switchSkill(skill) {
        // Atualizar botões
        skillBtns.forEach(b => {
          const active = b.dataset.skill === skill;
          b.classList.toggle('active', active);
          b.setAttribute('aria-pressed', String(active));
        });

        // Atualizar label do painel direito
        if (rightLabel) rightLabel.textContent = 'Projetos ' + skill;

        // Remover todos os itens imediatamente (sem animação de saída)
        projectItems.forEach(item => {
          item.classList.remove('visible', 'animating');
        });

        // Entrada com fade+slide escalonado para os novos itens
        const incoming = Array.from(projectItems).filter(
          item => item.dataset.skill === skill
        );
        incoming.forEach((item, i) => {
          item.style.setProperty('--item-i', String(i));
          item.classList.add('animating');
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              item.classList.add('visible');
            });
          });
        });

        // Repor scroll ao topo e verificar fade
        if (scrollContainer) {
          scrollContainer.scrollTop = 0;
          requestAnimationFrame(updateFade);
        }
      }

      // Verificação inicial de fade ao abrir o painel
      megaItem.addEventListener('mouseenter', () => requestAnimationFrame(updateFade));

      skillBtns.forEach(btn => {
        btn.addEventListener('mouseenter', () => switchSkill(btn.dataset.skill));
        btn.addEventListener('focus',      () => switchSkill(btn.dataset.skill));
        btn.addEventListener('click',      () => switchSkill(btn.dataset.skill));
      });

      // Links de projetos no mega menu — fechar painel ao clicar
      megaPanel.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          megaPanel.classList.remove('open');
          megaTrigger.setAttribute('aria-expanded', 'false');
        });
      });
    }

    // ============================================
    // SCROLL SUAVE
    // ============================================
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        const href = this.getAttribute('href');
        if (href && href !== '#') {
          e.preventDefault();
          const target = document.querySelector(href);
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            history.pushState(null, '', href);
            if (menu?.classList.contains('active')) btn?.click();
          }
        }
      });
    });

    // ============================================
    // PRÉ-CARREGAMENTO AO PASSAR O RATO (desktop)
    // ============================================
    if (window.matchMedia('(hover: hover)').matches) {
      document.querySelectorAll('a[href^="http"]').forEach(link => {
        link.addEventListener('mouseenter', () => {
          const url = link.getAttribute('href');
          if (url && !document.querySelector(`link[rel="prefetch"][href="${url}"]`)) {
            const prefetch = document.createElement('link');
            prefetch.rel = 'prefetch';
            prefetch.href = url;
            document.head.appendChild(prefetch);
          }
        }, { once: true });
      });
    }
  </script>

  <script is:inline>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      });
    }
  </script>
</body>
</html>