        <!-- CORRIGIDO: Usar var(--text-primary) em vez de #fff -->
        <span class="gh-lang-name" style="color: var(--text-primary); ${isTop ? 'font-weight:700; font-size:0.9rem;' : 'font-size:0.8rem;'}">
          ${lang}
        </span>

        <!-- CORRIGIDO: Usar var(--accent-cyan) para a percentagem acompanhar o tema -->
        <span class="gh-lang-pct" style="margin-left: auto; color: var(--accent-cyan); font-weight: 600; ${isTop ? 'font-size:0.85rem;' : 'font-size:0.75rem;'}">
          ${pct}%
        </span>
      </div>

      <!-- CORRIGIDO: Fundo da barra usa var(--border-color) para ser visível em ambos os modos -->
      <div class="gh-lang-bar-bg" style="background: var(--border-color); border-radius: 4px; overflow: hidden; ${isTop ? 'height:6px;' : 'height:4px;'}">
        <div class="gh-lang-bar-fill" style="width:${pct}%; height:100%; background:${color}; transition: width 1s ease-out;"></div>
      </div>
    </div>`;
};

    const top3 = sortedLangs.slice(0, 3);
    const theRest = sortedLangs.slice(3);
    const restHtml = theRest.length
      ? `<div style="position:relative;margin-top:12px;">
          <div style="display:none;position:absolute;top:calc(100% + 6px);left:0;right:0;z-index:50;background:#0f1318;border:1px solid rgba(14,165,233,0.2);border-radius:10px;padding:12px 14px;box-shadow:0 8px 30px rgba(0,0,0,0.5);max-height:200px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:rgba(14,165,233,0.3) transparent;">
            <div style="font-size:0.65rem;font-weight:700;letter-spacing:1.5px;color:rgba(157,165,176,0.4);text-transform:uppercase;margin-bottom:10px;">Also used</div>
            ${theRest.map(e => renderBar(e, false)).join('')}
          </div>
        </div>` : '';

const langsEl = document.getElementById('ghLangs');
if (langsEl) {
  langsEl.innerHTML = `
    <div class="gh-card-inner">
      <!-- Usamos var(--accent-cyan) em vez de cor fixa -->
      <div class="gh-card-title" style="color: var(--accent-cyan); font-weight:700;">
        Most Used Languages
        <!-- Usamos var(--text-secondary) com opacidade para o subtitulo -->
        <span style="margin-left:auto; font-size:0.65rem; color: var(--text-secondary); opacity: 0.6; font-weight:400;">
          by bytes of code
        </span>
      </div>
      ${top3.map(e => renderBar(e, true)).join('')}
      ${restHtml}
    </div>`;
}

    // ✅ Só mostra o grid se tudo correu bem
    const grid = document.getElementById('githubStatsGrid');
    if (grid) grid.style.display = '';

  } catch(e) {
    // Silencioso — os containers ficam hidden
  }
