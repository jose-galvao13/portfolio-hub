  <script>
    // Project filtering
  // Selecionar os elementos base
    const filterSelect = document.getElementById('skillFilter') as HTMLSelectElement;
    const projectsGrid = document.getElementById('projectsGrid') as HTMLElement;
    
    // Guardamos todos os cards originais numa array permanente no carregamento da página
    const allCards = Array.from(projectsGrid.querySelectorAll('.project-card')) as HTMLElement[];

    function updateProjects() {
      if (!filterSelect || !projectsGrid) return;

      const selectedSkill = filterSelect.value;
      
      // 1. Limpar a grelha atual (remove cards e as linhas divider antigas)
      projectsGrid.innerHTML = '';

      // 2. Filtrar os cards com base no texto das .skill-pill
      const visibleCards = allCards.filter(card => {
        // Extrai as skills de dentro das pills do card
        const skills = Array.from(card.querySelectorAll('.skill-pill')).map(
          pill => pill.textContent?.trim() || ''
        );
        
        return selectedSkill === 'all' || skills.includes(selectedSkill);
      });

      // 3. Reinserir os cards filtrados na grelha
      visibleCards.forEach((card, index) => {
        // Garantir que o card está visível e adicioná-lo à grid
        card.style.display = 'block';
        projectsGrid.appendChild(card);

        // 4. Lógica da Linha Divisória (apenas se houver 2 colunas)
        // Adiciona a linha após cada 2 cards, exceto se for o último projeto
        const isEverySecond = (index + 1) % 2 === 0;
        const isNotLast = index !== visibleCards.length - 1;

        // Só criamos a linha se estivermos em desktop (grelha de 2 colunas)
        if (window.innerWidth > 1024 && isEverySecond && isNotLast) {
          const divider = document.createElement('div');
          divider.className = 'project-row-divider';
          projectsGrid.appendChild(divider);
        }
      });
    }

    // Escutar a mudança no select
    filterSelect?.addEventListener('change', updateProjects);

    // Calculator functionality
    function updateCalculator() {
    const ids = ['processes', 'hours', 'rate'];
    let allValid = true;

    // 1. Validar todos os campos primeiro
    ids.forEach(id => {
      const inputEl = document.getElementById(id) as HTMLInputElement;
      const errorEl = document.getElementById(`error-${id}`); // Procura o span de erro
      const val = parseInt(inputEl.value);
      const min = parseInt(inputEl.getAttribute('min') || '0');
      const max = parseInt(inputEl.getAttribute('max') || '999999');

      if (isNaN(val) || val < min || val > max) {
        inputEl.classList.add('invalid');
        if (errorEl) errorEl.style.display = 'block';
        allValid = false;
      } else {
        inputEl.classList.remove('invalid');
        if (errorEl) errorEl.style.display = 'none';
      }
    });

    // 2. Se houver erro, resetar os textos e sair da função
    if (!allValid) {
      document.getElementById('savingsValue')!.textContent = "---";
      document.getElementById('monthlyValue')!.textContent = "---";
      document.getElementById('dailyValue')!.textContent = "---";
      document.getElementById('fteValue')!.textContent = "0";
      document.getElementById('hoursValue')!.textContent = "0";
      return;
    }

    // 3. Se estiver tudo OK, realizar o cálculo
    const processes = parseInt((document.getElementById('processes') as HTMLInputElement).value);
    const hours = parseInt((document.getElementById('hours') as HTMLInputElement).value);
    const rate = parseInt((document.getElementById('rate') as HTMLInputElement).value);
    
    const efficiency = 0.85;
    const totalHours = processes * hours * 52;
    const hoursSaved = totalHours * efficiency;
    const savings = hoursSaved * rate;
    const fte = hoursSaved / 1760;
    
    document.getElementById('savingsValue')!.textContent = `€${savings.toLocaleString('pt-PT', {maximumFractionDigits: 0})}`;
    document.getElementById('hoursValue')!.textContent = hoursSaved.toLocaleString('pt-PT', {maximumFractionDigits: 0});
    document.getElementById('fteValue')!.textContent = fte.toFixed(1);
    document.getElementById('monthlyValue')!.textContent = `€${(savings/12).toLocaleString('pt-PT', {maximumFractionDigits: 0})}`;
    document.getElementById('dailyValue')!.textContent = `${(hoursSaved/250).toFixed(1)}h`;
  }

  ['processes', 'hours', 'rate'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', updateCalculator);
  });

    // LIGHTBOX LOGIC
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement;
    const closeBtn = document.getElementById('closeLightbox');
    const prevBtn = document.getElementById('prevLightbox');
    const nextBtn = document.getElementById('nextLightbox');
    const overlay = document.querySelector('.lightbox-overlay');

    let currentProjectImages: string[] = [];
    let currentIndex = 0;

    function openLightbox(imgSrc: string, allImages: string[]) {
      currentProjectImages = allImages;
      currentIndex = allImages.indexOf(imgSrc);
      
      updateLightboxImage();
      
      lightbox?.classList.add('active');
      document.body.style.overflow = 'hidden'; // Impede scroll ao fundo

      // Esconde setas se houver apenas 1 imagem
      if (allImages.length <= 1) {
        prevBtn!.style.display = 'none';
        nextBtn!.style.display = 'none';
      } else {
        prevBtn!.style.display = 'flex';
        nextBtn!.style.display = 'flex';
      }
    }

    function updateLightboxImage() {
      lightboxImg.src = currentProjectImages[currentIndex];
    }

    function closeLightbox() {
      lightbox?.classList.remove('active');
      document.body.style.overflow = 'auto';
    }

    function nextImage() {
      currentIndex = (currentIndex + 1) % currentProjectImages.length;
      updateLightboxImage();
    }

    function prevImage() {
      currentIndex = (currentIndex - 1 + currentProjectImages.length) % currentProjectImages.length;
      updateLightboxImage();
    }

    // Event Listeners para as imagens nos ProjectCards
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      
      if (target.classList.contains('project-image')) {
        const card = target.closest('.project-card');
        if (card) {
          // Seleciona todas as imagens dentro desse card específico (slideshow)
          const imagesInCard = Array.from(card.querySelectorAll('.project-image')).map(
            (img: any) => img.src
          );
          openLightbox((target as HTMLImageElement).src, imagesInCard);
        }
      }
    });

    // Fechar
    closeBtn?.addEventListener('click', closeLightbox);
    overlay?.addEventListener('click', closeLightbox);

    // Navegação
    nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); nextImage(); });
    prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); prevImage(); });

    // Teclas de atalho (ESC, Setas)
    document.addEventListener('keydown', (e) => {
      if (!lightbox?.classList.contains('active')) return;
      
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') nextImage();
      if (e.key === 'ArrowLeft') prevImage();
    });
  </script>
