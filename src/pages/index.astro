  let wasExpanded = false;

  // ============================================================
  // SCROLL PROGRESS BAR
  // ============================================================
  window.addEventListener('scroll', () => {
    const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    if (scrollProgress) scrollProgress.style.width = ((winScroll / height) * 100) + '%';
  }, { passive: true });

  // ============================================================
  // ANIMATED COUNTERS
  // ============================================================
  function animateCounter(el, target, suffix = '', duration = 2000) {
    let current = 0;
    const step = target / (duration / 16);
    const timer = setInterval(() => {
      current += step;
      if (current >= target) { current = target; clearInterval(timer); }
      el.textContent = Math.floor(current) + suffix;
    }, 16);
  }

  const statsObserver = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      entry.target.querySelectorAll('.stat-value').forEach(stat => {
        animateCounter(stat, parseInt(stat.dataset.target || '0'), stat.dataset.suffix || '');
      });
      statsObserver.unobserve(entry.target);
    });
  }, { threshold: 0.3 });

  const statsSection = document.querySelector('.stats-section');
  if (statsSection) statsObserver.observe(statsSection);

  // ============================================================
  // SKILL FILTER
  // ============================================================
  function updateProjects() {
    if (!filterSelect || !featuredGrid || !otherGrid) return;

    const selectedSkill = filterSelect.value;
    const isFiltering = selectedSkill !== 'all';

    const otherSection = document.querySelector('.other-projects-section');

    if (isFiltering) {
      wasExpanded = otherProjectsContainer
        ? otherProjectsContainer.classList.contains('expanded')
        : false;

      originalOtherCards.forEach(card => featuredGrid.appendChild(card));
      if (otherSection) otherSection.style.display = 'none';
      if (otherProjectsContainer) otherProjectsContainer.style.display = 'none';
      if (expandBtn) expandBtn.style.display = 'none';

      featuredGrid.querySelectorAll('.glass-project-card').forEach(card => {
        const skills = Array.from(card.querySelectorAll('.tech-tag')).map(t => t.textContent.trim());
        const isMatch = skills.includes(selectedSkill);
        card.style.display = isMatch ? 'block' : 'none';
        card.style.opacity = isMatch ? '1' : '0';
      });
    } else {
      originalOtherCards.forEach(card => otherGrid.appendChild(card));

      document.querySelectorAll('.glass-project-card').forEach(card => {
        card.style.display = 'block';
        card.style.opacity = '1';
      });

      if (otherSection) otherSection.style.display = '';
      if (otherProjectsContainer) otherProjectsContainer.style.display = '';
      if (expandBtn) expandBtn.style.display = '';
    }
  }

  if (filterSelect) filterSelect.addEventListener('change', updateProjects);

  // ============================================================
  // EXPAND / COLLAPSE
  // ============================================================
  function setExpandState(expanded) {
    if (!otherProjectsContainer || !expandBtn || !collapseBtn) return;

    if (expanded) {
      otherProjectsContainer.classList.add('expanded');
      otherProjectsContainer.setAttribute('aria-hidden', 'false');
      expandBtn.style.display = 'none';
      collapseBtn.style.display = 'flex';
      expandBtn.setAttribute('aria-expanded', 'true');
    } else {
      otherProjectsContainer.classList.remove('expanded');
      otherProjectsContainer.setAttribute('aria-hidden', 'true');
      expandBtn.style.display = 'flex';
      collapseBtn.style.display = 'none';
      expandBtn.setAttribute('aria-expanded', 'false');
    }
  }

  setExpandState(false);

  if (expandBtn) {
    expandBtn.addEventListener('click', () => {
      setExpandState(true);
      setTimeout(() => {
        otherProjectsContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }, 300);
    });
  }

  if (collapseBtn) {
    collapseBtn.addEventListener('click', () => {
      setExpandState(false);
      document.getElementById('portfolio')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }

  // ============================================================
  // SCROLL REVEAL
  // ============================================================
  const revealObserver = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); });
  }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });

  document.querySelectorAll('.reveal, .reveal-stagger, .hero-reveal').forEach(el => revealObserver.observe(el));

  // ============================================================
  // GLASSMORPHISM GLOW ON HOVER
  // ============================================================
  function addGlowEffect(selector) {
    document.querySelectorAll(selector).forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--mouse-x', ((e.clientX - rect.left) / rect.width * 100) + '%');
        card.style.setProperty('--mouse-y', ((e.clientY - rect.top) / rect.height * 100) + '%');
      });
      card.addEventListener('mouseleave', () => {
        card.style.removeProperty('--mouse-x');
        card.style.removeProperty('--mouse-y');
      });
    });
  }

  addGlowEffect('.stat-card');
  addGlowEffect('.glass-project-card');
  addGlowEffect('.skill-group-card');
  addGlowEffect('.soft-skill-card');
  addGlowEffect('.lang-card');
  addGlowEffect('.insight-card');

  // ============================================================
  // PARALLAX PROFILE PICTURE
  // ============================================================
  const profilePic = document.querySelector('.profile-pic');
  if (profilePic) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          profilePic.style.setProperty('--parallax-y', `${-(window.scrollY * 0.3)}px`);
          profilePic.classList.add('parallax-active');
          ticking = false;
        });
        ticking = true;
      }
    });
  }

  // ============================================================
  // EFFICIENCY CALCULATOR
  // ============================================================
  const processesInput   = document.getElementById('processes');
  const hoursInput       = document.getElementById('hours');
  const rateInput        = document.getElementById('rate');
  const rateLabel        = document.getElementById('rateLabel');
  const currencySelector = document.getElementById('currencySelector');

  let lastSavings = 0;

  function getCurrencyConfig() {
    if (!currencySelector) return { symbol: '€', min: 15, max: 150, defaultRate: 40 };
    const opt = currencySelector.options[currencySelector.selectedIndex];
    return {
      symbol:      opt.getAttribute('data-symbol') || '€',
      min:         parseInt(opt.getAttribute('data-min') || '15'),
      max:         parseInt(opt.getAttribute('data-max') || '150'),
      defaultRate: parseInt(opt.getAttribute('data-default') || '40'),
    };
  }

  function validateInput(input, min, max) {
    const val = parseInt(input.value);
    const err = document.getElementById(`error-${input.id}`);
    const ok  = !isNaN(val) && val >= min && val <= max;
    input.classList.toggle('input-warning', !ok);
    if (err) { err.textContent = `Value between ${min} and ${max}`; err.style.display = ok ? 'none' : 'block'; }
    return ok;
  }

  function fmt(value, symbol) {
    return `${symbol}${Math.floor(value).toLocaleString(symbol === 'R$' ? 'pt-BR' : 'en-US')}`;
  }

  function animateROI(id, start, end, symbol) {
    const el = document.getElementById(id);
    if (!el) return;
    let startTime = null;
    const step = (ts) => {
      if (!startTime) startTime = ts;
      const p = Math.min((ts - startTime) / 500, 1);
      el.textContent = fmt(p * (end - start) + start, symbol);
      if (p < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  function calculateEfficiency() {
    if (!processesInput || !hoursInput || !rateInput) return;
    const cfg = getCurrencyConfig();
    const ok  = validateInput(processesInput, 1, 50)
              & validateInput(hoursInput, 1, 40)
              & validateInput(rateInput, cfg.min, cfg.max);

    if (rateLabel) rateLabel.textContent = `💳 Analyst Hourly Rate (${cfg.symbol})`;

    const resultCard = document.querySelector('.result-card');
    if (resultCard) {
      resultCard.style.opacity       = ok ? '1' : '0.5';
      resultCard.style.filter        = ok ? 'none' : 'blur(1px)';
      resultCard.style.pointerEvents = ok ? 'auto' : 'none';
    }
    if (!ok) return;

    const p = parseInt(processesInput.value);
    const h = parseInt(hoursInput.value);
    const r = parseInt(rateInput.value);
    const annualHours   = p * h * 52;
    const annualSavings = annualHours * r;

    animateROI('savingsValue', lastSavings, annualSavings, cfg.symbol);
    lastSavings = annualSavings;

    const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
    set('hoursValue',   annualHours.toLocaleString());
    set('fteValue',     (annualHours / 2080).toFixed(1));
    set('monthlyValue', fmt(annualSavings / 12, cfg.symbol));
    set('dailyValue',   ((p * h) / 5).toFixed(1) + 'h');
  }

  [processesInput, hoursInput, rateInput].forEach(el => el?.addEventListener('input', calculateEfficiency));
  currencySelector?.addEventListener('change', () => {
    if (rateInput) rateInput.value = String(getCurrencyConfig().defaultRate);
    calculateEfficiency();
  });
  calculateEfficiency();

  // ============================================================
  // ROI EXPORT AS IMAGE (canvas-based, no external lib needed)
  // ============================================================
  document.getElementById('exportRoiBtn')?.addEventListener('click', () => {
    const cfg = getCurrencyConfig();
    const savings   = document.getElementById('savingsValue')?.textContent || '';
    const hours     = document.getElementById('hoursValue')?.textContent   || '';
    const fte       = document.getElementById('fteValue')?.textContent     || '';
    const monthly   = document.getElementById('monthlyValue')?.textContent || '';
    const daily     = document.getElementById('dailyValue')?.textContent   || '';
    const processes = (processesInput as HTMLInputElement)?.value || '';
    const hoursVal  = (hoursInput    as HTMLInputElement)?.value || '';
    const rate      = (rateInput     as HTMLInputElement)?.value || '';

    const W = 900, H = 500;
    const canvas = document.createElement('canvas');
    canvas.width  = W * 2; // retina
    canvas.height = H * 2;
    canvas.style.width  = W + 'px';
    canvas.style.height = H + 'px';
    const ctx = canvas.getContext('2d')!;
    ctx.scale(2, 2);

    // Background
    const grad = ctx.createLinearGradient(0, 0, W, H);
    grad.addColorStop(0, '#0a0c10');
    grad.addColorStop(1, '#0f1318');
    ctx.fillStyle = grad;
    ctx.roundRect(0, 0, W, H, 20);
    ctx.fill();

    // Border glow
    ctx.strokeStyle = 'rgba(14,165,233,0.4)';
    ctx.lineWidth = 1.5;
    ctx.roundRect(1, 1, W - 2, H - 2, 19);
    ctx.stroke();

    // Top accent line
    const lineGrad = ctx.createLinearGradient(80, 0, W - 80, 0);
    lineGrad.addColorStop(0, 'transparent');
    lineGrad.addColorStop(0.5, '#0EA5E9');
    lineGrad.addColorStop(1, 'transparent');
    ctx.strokeStyle = lineGrad;
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(80, 1); ctx.lineTo(W - 80, 1);
    ctx.stroke();

    // Label
    ctx.fillStyle = 'rgba(14,165,233,0.7)';
    ctx.font = 'bold 11px Inter, sans-serif';
    ctx.letterSpacing = '3px';
    ctx.textAlign = 'center';
    ctx.fillText('🚀  ANNUAL FINANCIAL RECOVERY', W / 2, 50);

    // Big number
    ctx.font = 'bold 72px Inter, sans-serif';
    ctx.letterSpacing = '-2px';
    const numGrad = ctx.createLinearGradient(W / 2 - 200, 0, W / 2 + 200, 0);
    numGrad.addColorStop(0, '#ffffff');
    numGrad.addColorStop(1, '#0EA5E9');
    ctx.fillStyle = numGrad;
    ctx.fillText(savings, W / 2, 140);

    // Sub-line
    ctx.font = '400 16px Inter, sans-serif';
    ctx.letterSpacing = '0px';
    ctx.fillStyle = 'rgba(157,165,176,0.9)';
    ctx.fillText(`Automating ${hours} hours/year · ${fte} FTE equivalent freed`, W / 2, 175);

    // Divider
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(60, 202); ctx.lineTo(W - 60, 202);
    ctx.stroke();

    // Metric boxes
    const metrics = [
      { label: 'MONTHLY SAVINGS', value: monthly },
      { label: 'DAILY TIME SAVED', value: daily },
      { label: 'EFFICIENCY GAIN', value: '+85%' },
    ];
    const mW = (W - 120) / 3;
    metrics.forEach((m, i) => {
      const x = 60 + i * (mW + 0);
      ctx.fillStyle = 'rgba(14,165,233,0.07)';
      ctx.roundRect(x, 220, mW - 10, 90, 12);
      ctx.fill();
      ctx.strokeStyle = 'rgba(14,165,233,0.2)';
      ctx.lineWidth = 1;
      ctx.roundRect(x, 220, mW - 10, 90, 12);
      ctx.stroke();

      ctx.font = 'bold 24px Inter, sans-serif';
      ctx.fillStyle = '#0EA5E9';
      ctx.textAlign = 'center';
      ctx.fillText(m.value, x + (mW - 10) / 2, 258);

      ctx.font = '600 10px Inter, sans-serif';
      ctx.letterSpacing = '1.5px';
      ctx.fillStyle = 'rgba(157,165,176,0.7)';
      ctx.fillText(m.label, x + (mW - 10) / 2, 278);
    });

    // Inputs used
    ctx.font = '400 12px Inter, sans-serif';
    ctx.letterSpacing = '0px';
    ctx.fillStyle = 'rgba(157,165,176,0.4)';
    ctx.textAlign = 'center';
    ctx.fillText(
      `Based on ${processes} processes · ${hoursVal}h/week · ${cfg.symbol}${rate}/h`,
      W / 2, 340
    );

    // Footer branding
    ctx.fillStyle = 'rgba(255,255,255,0.08)';
    ctx.fillRect(0, H - 56, W, 56);

    ctx.font = 'bold 14px Inter, sans-serif';
    ctx.letterSpacing = '0px';
    ctx.fillStyle = 'rgba(255,255,255,0.7)';
    ctx.textAlign = 'left';
    ctx.fillText('José Galvão · Business Data Analyst', 40, H - 24);

    ctx.textAlign = 'right';
    ctx.fillStyle = 'rgba(14,165,233,0.7)';
    ctx.fillText('jose-galvao13.github.io/portfolio-hub', W - 40, H - 24);

    // Trigger download
    const a = document.createElement('a');
    a.download = 'roi-analysis-jose-galvao.png';
    a.href = canvas.toDataURL('image/png');
    a.click();
  });

  // ============================================================
  // LIGHTBOX
  // ============================================================
  const lightbox        = document.getElementById('lightbox');
  const lightboxImg     = document.getElementById('lightboxImg');
  const closeLightbox   = document.getElementById('closeLightbox');
  const prevLightbox    = document.getElementById('prevLightbox');
  const nextLightbox    = document.getElementById('nextLightbox');
  const lightboxOverlay = document.querySelector('.lightbox-overlay');

  let currentImages = [];
  let currentAlts   = [];
  let currentIndex  = 0;

  if (lightbox && lightboxImg && closeLightbox && prevLightbox && nextLightbox && lightboxOverlay) {
    document.querySelectorAll('.carousel-img').forEach(img => {
      img.addEventListener('click', () => {
        const card = img.closest('.glass-project-card');
        if (!card) return;
        const allImgs = Array.from(card.querySelectorAll('.carousel-img'));
        currentImages = allImgs.map(i => i.src);
        currentAlts   = allImgs.map(i => i.alt);
        currentIndex  = allImgs.findIndex(i => i.classList.contains('active'));
        if (currentIndex < 0) currentIndex = 0;
        updateLightbox();
        lightbox.classList.add('active');
        document.body.style.overflow = 'hidden';
        closeLightbox.focus();
      });
    });

    function updateLightbox() {
      if (currentImages.length > 0) {
        lightboxImg.src = currentImages[currentIndex];
        lightboxImg.alt = currentAlts[currentIndex] || '';
      }
    }

    nextLightbox.addEventListener('click', e => { e.stopPropagation(); currentIndex = (currentIndex + 1) % currentImages.length; updateLightbox(); });
    prevLightbox.addEventListener('click', e => { e.stopPropagation(); currentIndex = (currentIndex - 1 + currentImages.length) % currentImages.length; updateLightbox(); });

    const closeLB = () => { lightbox.classList.remove('active'); document.body.style.overflow = 'auto'; };
    closeLightbox.addEventListener('click', closeLB);
    lightboxOverlay.addEventListener('click', closeLB);
    document.addEventListener('keydown', e => {
      if (!lightbox.classList.contains('active')) return;
      if (e.key === 'Escape') closeLB();
      if (e.key === 'ArrowRight') nextLightbox.click();
      if (e.key === 'ArrowLeft')  prevLightbox.click();
    });
  }


  // ============================================================
// GITHUB STATS VIA API
// ============================================================
async function loadGitHubStats() {
  const username = 'jose-galvao13';
  
  try {
    const [userRes, reposRes] = await Promise.all([
      fetch(`https://api.github.com/users/${username}`),
      fetch(`https://api.github.com/users/${username}/repos?per_page=100&sort=updated`)
    ]);
    
    if (!userRes.ok || !reposRes.ok) return; // esconde silenciosamente
    
    const user = await userRes.json();
    const repos = await reposRes.json();
    if (!Array.isArray(repos) || user.public_repos === undefined) return;

    // ── Stats Card ──────────────────────────────────────────
    const statsEl = document.getElementById('ghStats');
    if (statsEl) {
      statsEl.innerHTML = `
        <div class="gh-card-inner">
          <div class="gh-card-title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="color:#0EA5E9">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            <span style="color:#0EA5E9;font-weight:700">${username} · Impact Metrics</span>
          </div>
          <div class="gh-stats-row">
            <div class="gh-stat"><span class="gh-stat-val">1.2M</span><span class="gh-stat-label">Rows Processed</span></div>
            <div class="gh-stat"><span class="gh-stat-val">88%</span><span class="gh-stat-label">Avg ML Accuracy</span></div>
            <div class="gh-stat"><span class="gh-stat-val">2d→5s</span><span class="gh-stat-label">Best Automation</span></div>
            <div class="gh-stat"><span class="gh-stat-val">${user.public_repos}</span><span class="gh-stat-label">Open Source Repos</span></div>
          </div>
        </div>`;
    }

    // ── Languages ───────────────────────────────────────────
    const nonForkRepos = repos.filter(r => !r.fork && r.size > 0).slice(0, 10);
    
    const langResults = await Promise.all(
      nonForkRepos.map(r =>
        fetch(r.languages_url)
          .then(res => res.ok ? res.json() : {})
          .catch(() => ({}))
      )
    );

    const langBytes = {};
    langResults.forEach(repoLangs => {
      Object.entries(repoLangs).forEach(([lang, bytes]) => {
        langBytes[lang] = (langBytes[lang] || 0) + (bytes as number);
      });
    });

    const ignoredLangs = ['Makefile', 'Dockerfile', 'Shell', 'Batchfile', 'PowerShell', 'Astro', 'MDX'];
    const sortedLangs = Object.entries(langBytes)
      .filter(([lang]) => !ignoredLangs.includes(lang))
      .sort((a, b) => (b[1] as number) - (a[1] as number));

    if (!sortedLangs.length) return; // sem dados = não mostra

    const totalBytes = sortedLangs.reduce((sum, [, b]) => sum + (b as number), 0);
    const colors = {
      Python: '#3776ab', JavaScript: '#f7df1e', TypeScript: '#2b7489',
      SQL: '#cc2927', 'C#': '#68217a', HTML: '#e34c26', CSS: '#563d7c',
      Java: '#b07219', 'Jupyter Notebook': '#da5b0b',
      R: '#198ce7', Go: '#00add8', Rust: '#dea584', SCSS: '#c6538c',
    };

   const renderBar = ([lang, bytes], isTop = false) => {
  const pct = ((bytes as number / totalBytes) * 100).toFixed(1);
  const color = colors[lang] || 'var(--accent-cyan)'; // Usa a cor da linguagem ou o ciano do tema

  return `
    <div class="gh-lang-item" style="${isTop ? 'margin-bottom:14px;' : 'margin-bottom:8px;'}">
